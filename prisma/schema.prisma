generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "core", "development", "management", "training"]
}

model Team {
  id                               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                        DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdBy                        String?            @map("created_by") @db.Uuid
  updatedBy                        String?            @map("updated_by") @db.Uuid
  metadata                         Json               @default("{}") @map("metadata")
  name                             String             @map("name")
  teamCode                         String             @unique @map("team_code")
  sport                            String             @default("american_football") @map("sport")
  city                             String?            @map("city")
  seasonYear                       Int                @map("season_year")
  description                      String?            @map("description")
  ownerUserId                      String?            @map("owner_user_id") @db.Uuid
  joinRequests                     JoinRequest[]
  players                          Player[]
  teamMembers                      TeamMember[]
  users_teams_created_byTousers    users?             @relation("teams_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  users_teams_owner_user_idTousers users?             @relation("teams_owner_user_idTousers", fields: [ownerUserId], references: [id], onUpdate: NoAction)
  users_teams_updated_byTousers    users?             @relation("teams_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)
  drillLibraries                   DrillLibrary[]
  iipAssignments                   IipAssignment[]
  performanceScores                PerformanceScore[]
  conditionLogs                    ConditionLog[]
  injuryReports                    InjuryReport[]
  monthlyDues                      MonthlyDue[]
  attendances                      Attendance[]
  events                           Event[]
  practiceCheckins                 PracticeCheckin[]
  trainingSchedules                TrainingSchedule[]

  @@map("teams")
  @@schema("core")
}

model Profile {
  id                               String    @id @db.Uuid
  createdAt                        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                        DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy                        String?   @map("created_by") @db.Uuid
  updatedBy                        String?   @map("updated_by") @db.Uuid
  metadata                         Json      @default("{}") @map("metadata")
  displayName                      String?   @map("display_name")
  phone                            String?   @map("phone")
  birthYear                        Int?      @map("birth_year")
  avatarUrl                        String?   @map("avatar_url")
  users_profiles_created_byTousers users?    @relation("profiles_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  users_profiles_idTousers         users     @relation("profiles_idTousers", fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_profiles_updated_byTousers users?    @relation("profiles_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)
  ownedMedia                       Media[]   @relation("ProfileOwnedMedia")

  @@map("profiles")
  @@schema("core")
}

/// Supabase 스토리지 경로 기준 미디어. 버킷 객체 삭제는 앱/워크플로에서 처리하고, DB는 FK·제약으로 안전하게 관리합니다.
model Media {
  id          String       @id @default(uuid()) @db.Uuid
  type        MediaType    @map("type")
  storagePath String       @map("storage_path")
  ownerId     String       @map("owner_id") @db.Uuid
  contextType MediaContext @map("context_type")
  title       String?      @map("title")
  caption     String?      @map("caption")
  metadata    Json?        @map("metadata")
  tags        String[]     @default([]) @map("tags")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner Profile @relation("ProfileOwnedMedia", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([ownerId])
  @@index([contextType])
  @@map("media")
  @@schema("core")
}

model Player {
  id                                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                           DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                           DateTime?            @map("deleted_at") @db.Timestamptz(6)
  createdBy                           String?              @map("created_by") @db.Uuid
  updatedBy                           String?              @map("updated_by") @db.Uuid
  metadata                            Json                 @default("{}") @map("metadata")
  teamId                              String               @map("team_id") @db.Uuid
  linkedUserId                        String?              @map("linked_user_id") @db.Uuid
  fullName                            String               @map("full_name")
  jerseyNumber                        Int?                 @map("jersey_number")
  primaryPosition                     String?              @map("primary_position")
  secondaryPosition                   String?              @map("secondary_position")
  unit                                String?              @map("unit")
  heightCm                            Decimal?             @map("height_cm") @db.Decimal(5, 1)
  weightKg                            Decimal?             @map("weight_kg") @db.Decimal(5, 1)
  joinYear                            Int?                 @map("join_year")
  rosterStatus                        player_roster_status @default(active) @map("roster_status")
  notes                               String?              @map("notes")
  users_players_created_byTousers     users?               @relation("players_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  users_players_linked_user_idTousers users?               @relation("players_linked_user_idTousers", fields: [linkedUserId], references: [id], onUpdate: NoAction)
  team                                Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_players_updated_byTousers     users?               @relation("players_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)
  teamMembers                         TeamMember[]
  iipAssignments                      IipAssignment[]
  performanceScores                   PerformanceScore[]
  conditionLogs                       ConditionLog[]
  injuryReports                       InjuryReport[]
  monthlyDues                         MonthlyDue[]
  attendances                         Attendance[]
  practiceCheckins                    PracticeCheckin[]

  @@map("players")
  @@schema("core")
}

model TeamMember {
  id                                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                            DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                            DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdBy                            String?            @map("created_by") @db.Uuid
  updatedBy                            String?            @map("updated_by") @db.Uuid
  metadata                             Json               @default("{}") @map("metadata")
  teamId                               String             @map("team_id") @db.Uuid
  userId                               String             @map("user_id") @db.Uuid
  role                                 team_member_role
  status                               team_member_status @default(pending)
  playerId                             String?            @map("player_id") @db.Uuid
  joinedAt                             DateTime?          @map("joined_at") @db.Timestamptz(6)
  invitedBy                            String?            @map("invited_by") @db.Uuid
  users_team_members_created_byTousers users?             @relation("team_members_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  users_team_members_invited_byTousers users?             @relation("team_members_invited_byTousers", fields: [invitedBy], references: [id], onUpdate: NoAction)
  player                               Player?            @relation(fields: [playerId], references: [id], onUpdate: NoAction)
  team                                 Team               @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_team_members_updated_byTousers users?             @relation("team_members_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)
  users_team_members_user_idTousers    users              @relation("team_members_user_idTousers", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([teamId, userId], map: "team_members_team_user_unique")
  @@map("team_members")
  @@schema("core")
}

model JoinRequest {
  id                                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                              DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                              DateTime?           @map("deleted_at") @db.Timestamptz(6)
  createdBy                              String?             @map("created_by") @db.Uuid
  updatedBy                              String?             @map("updated_by") @db.Uuid
  metadata                               Json                @default("{}") @map("metadata")
  teamId                                 String              @map("team_id") @db.Uuid
  userId                                 String              @map("user_id") @db.Uuid
  requestedRole                          team_member_role    @map("requested_role")
  requestedPosition                      String?             @map("requested_position")
  requestedUnit                          String?             @map("requested_unit")
  jerseyNumber                           Int?                @map("jersey_number")
  heightCm                               Decimal?            @map("height_cm") @db.Decimal(5, 1)
  weightKg                               Decimal?            @map("weight_kg") @db.Decimal(5, 1)
  message                                String?             @map("message")
  status                                 join_request_status @default(pending)
  reviewedBy                             String?             @map("reviewed_by") @db.Uuid
  reviewedAt                             DateTime?           @map("reviewed_at") @db.Timestamptz(6)
  rejectReason                           String?             @map("reject_reason")
  users_join_requests_created_byTousers  users?              @relation("join_requests_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  users_join_requests_reviewed_byTousers users?              @relation("join_requests_reviewed_byTousers", fields: [reviewedBy], references: [id], onUpdate: NoAction)
  team                                   Team                @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_join_requests_updated_byTousers  users?              @relation("join_requests_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)
  users_join_requests_user_idTousers     users               @relation("join_requests_user_idTousers", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("join_requests")
  @@schema("core")
}

model Event {
  id                             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                      DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                      DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdBy                      String?            @map("created_by") @db.Uuid
  updatedBy                      String?            @map("updated_by") @db.Uuid
  metadata                       Json               @default("{}") @map("metadata")
  teamId                         String             @map("team_id") @db.Uuid
  title                          String             @map("title")
  eventType                      event_type         @default(practice) @map("event_type")
  startsAt                       DateTime           @map("starts_at") @db.Timestamptz(6)
  endsAt                         DateTime?          @map("ends_at") @db.Timestamptz(6)
  location                       String?            @map("location")
  opponent                       String?            @map("opponent")
  isMandatory                    Boolean            @default(false) @map("is_mandatory")
  notes                          String?            @map("notes")
  status                         event_status       @default(scheduled)
  performanceScores              PerformanceScore[]
  attendances                    Attendance[]
  users_events_created_byTousers users?             @relation("events_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  team                           Team               @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_events_updated_byTousers users?             @relation("events_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)
  practiceCheckins               PracticeCheckin[]

  @@map("events")
  @@schema("training")
}

model Attendance {
  id                                              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                                       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                                       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdBy                                       String?           @map("created_by") @db.Uuid
  updatedBy                                       String?           @map("updated_by") @db.Uuid
  metadata                                        Json              @default("{}") @map("metadata")
  teamId                                          String            @map("team_id") @db.Uuid
  eventId                                         String            @map("event_id") @db.Uuid
  playerId                                        String            @map("player_id") @db.Uuid
  status                                          attendance_status @default(undecided)
  absenceReason                                   String?           @map("absence_reason")
  lastChangedByUserId                             String?           @map("last_changed_by_user_id") @db.Uuid
  users_attendance_created_byTousers              users?            @relation("attendance_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  event                                           Event             @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_attendance_last_changed_by_user_idTousers users?            @relation("attendance_last_changed_by_user_idTousers", fields: [lastChangedByUserId], references: [id], onUpdate: NoAction)
  player                                          Player            @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team                                            Team              @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_attendance_updated_byTousers              users?            @relation("attendance_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)

  @@map("attendance")
  @@schema("training")
}

model TrainingSchedule {
  id                                              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                                       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                       DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                                       DateTime?                @map("deleted_at") @db.Timestamptz(6)
  createdBy                                       String?                  @map("created_by") @db.Uuid
  updatedBy                                       String?                  @map("updated_by") @db.Uuid
  metadata                                        Json                     @default("{}") @map("metadata")
  teamId                                          String                   @map("team_id") @db.Uuid
  title                                           String                   @map("title")
  scheduleDate                                    DateTime                 @map("schedule_date") @db.Date
  timezone                                        String                   @default("Asia/Seoul") @map("timezone")
  location                                        String?                  @map("location")
  status                                          training_schedule_status @default(draft)
  coachAuthorId                                   String?                  @map("coach_author_id") @db.Uuid
  submittedAt                                     DateTime?                @map("submitted_at") @db.Timestamptz(6)
  approvedBy                                      String?                  @map("approved_by") @db.Uuid
  approvedAt                                      DateTime?                @map("approved_at") @db.Timestamptz(6)
  rejectedBy                                      String?                  @map("rejected_by") @db.Uuid
  rejectedAt                                      DateTime?                @map("rejected_at") @db.Timestamptz(6)
  rejectReason                                    String?                  @map("reject_reason")
  publishedAt                                     DateTime?                @map("published_at") @db.Timestamptz(6)
  blocks                                          TrainingBlock[]
  users_training_schedules_approved_byTousers     users?                   @relation("training_schedules_approved_byTousers", fields: [approvedBy], references: [id], onUpdate: NoAction)
  users_training_schedules_coach_author_idTousers users?                   @relation("training_schedules_coach_author_idTousers", fields: [coachAuthorId], references: [id], onUpdate: NoAction)
  users_training_schedules_created_byTousers      users?                   @relation("training_schedules_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  users_training_schedules_rejected_byTousers     users?                   @relation("training_schedules_rejected_byTousers", fields: [rejectedBy], references: [id], onUpdate: NoAction)
  team                                            Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_training_schedules_updated_byTousers      users?                   @relation("training_schedules_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)

  @@map("training_schedules")
  @@schema("training")
}

model TrainingBlock {
  id                                         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                                  DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                  DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                                  DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  createdBy                                  String?                   @map("created_by") @db.Uuid
  updatedBy                                  String?                   @map("updated_by") @db.Uuid
  metadata                                   Json                      @default("{}") @map("metadata")
  trainingScheduleId                         String                    @map("training_schedule_id") @db.Uuid
  coachUserId                                String                    @map("coach_user_id") @db.Uuid
  blockType                                  training_block_type       @default(drill) @map("block_type")
  columnUnit                                 training_column_unit      @map("column_unit")
  title                                      String                    @map("title")
  startsAt                                   DateTime                  @map("starts_at") @db.Timestamptz(6)
  endsAt                                     DateTime                  @map("ends_at") @db.Timestamptz(6)
  intensity                                  training_block_intensity? @map("intensity")
  positionFocus                              String?                   @map("position_focus")
  sortOrder                                  Int                       @default(0) @map("sort_order")
  parentBlockId                              String?                   @map("parent_block_id") @db.Uuid
  users_training_blocks_coach_user_idTousers users                     @relation("training_blocks_coach_user_idTousers", fields: [coachUserId], references: [id], onUpdate: NoAction)
  users_training_blocks_created_byTousers    users?                    @relation("training_blocks_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  parentBlock                                TrainingBlock?            @relation("BlockHierarchy", fields: [parentBlockId], references: [id], onUpdate: NoAction)
  childBlocks                                TrainingBlock[]           @relation("BlockHierarchy")
  schedule                                   TrainingSchedule          @relation(fields: [trainingScheduleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_training_blocks_updated_byTousers    users?                    @relation("training_blocks_updated_byTousers", fields: [updatedBy], references: [id], onUpdate: NoAction)

  @@map("training_blocks")
  @@schema("training")
}

model PracticeCheckin {
