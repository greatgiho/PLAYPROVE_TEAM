  createdAt                                    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                    DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                                    DateTime?               @map("deleted_at") @db.Timestamptz(6)
  createdBy                                    String?                 @map("created_by") @db.Uuid
  updatedBy                                    String?                 @map("updated_by") @db.Uuid
  metadata                                     Json                    @default("{}") @map("metadata")
  teamId                                       String                  @map("team_id") @db.Uuid
  playerId                                     String                  @map("player_id") @db.Uuid
  coachUserId                                  String?                 @map("coach_user_id") @db.Uuid
  eventId                                      String?                 @map("event_id") @db.Uuid
  practiceDate                                 DateTime                @map("practice_date") @db.Date
  status                                       practice_checkin_status @default(draft)
  starRating                                   Int?                    @map("star_rating")
  effortTag                                    String?                 @map("effort_tag")
  coachCommentOneLiner                         String?                 @map("coach_comment_one_liner")
