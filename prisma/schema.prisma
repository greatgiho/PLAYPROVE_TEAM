  @@schema("development")
}

model PerformanceScore {
  id                                            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                                     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                                     DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdBy                                     String?         @map("created_by") @db.Uuid
  updatedBy                                     String?         @map("updated_by") @db.Uuid
  metadata                                      Json            @default("{}") @map("metadata")
  teamId                                        String          @map("team_id") @db.Uuid
  playerId                                      String          @map("player_id") @db.Uuid
  coachUserId                                   String          @map("coach_user_id") @db.Uuid
  sourceEventId                                 String?         @map("source_event_id") @db.Uuid
  evaluatedOn                                   DateTime        @default(dbgenerated("CURRENT_DATE")) @map("evaluated_on") @db.Date
  physical                                      Decimal         @map("physical") @db.Decimal(4, 1)
  skill                                         Decimal         @map("skill") @db.Decimal(4, 1)
  tactical                                      Decimal         @map("tactical") @db.Decimal(4, 1)
  attendanceMetric                              Decimal         @map("attendance_metric") @db.Decimal(4, 1)
  mental                                        Decimal         @map("mental") @db.Decimal(4, 1)
  coachComment                                  String?         @map("coach_comment")
  keywordTags                                   String[]        @default([]) @map("keyword_tags")
  isVisibleToPlayer                             Boolean         @default(true) @map("is_visible_to_player")
  iipFromSource                                 IipAssignment[] @relation("PerfToIip")
  users_performance_scores_coach_user_idTousers users           @relation("performance_scores_coach_user_idTousers", fields: [coachUserId], references: [id], onUpdate: NoAction)
  users_performance_scores_created_byTousers    users?          @relation("performance_scores_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
  player                                        Player          @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
