  suggestedUnit                         String?         @map("suggested_unit")
  suggestedPositions                    String[]        @map("suggested_positions")
  users_drill_library_created_byTousers users?          @relation("drill_library_created_byTousers", fields: [createdBy], references: [id], onUpdate: NoAction)
