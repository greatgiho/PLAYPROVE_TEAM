// PlayProve — PostgreSQL 다중 스키마 (core / training / development / management)
// Prisma 5.22+ : previewFeatures = ["multiSchema"] + datasource.schemas + model/enum @@schema
// 검증: DATABASE_URL=postgresql://... npx prisma validate

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "training", "development", "management"]
}

// ---------------------------------------------------------------------------
// core enums
// ---------------------------------------------------------------------------

enum JoinRequestStatus {
  pending
  approved
  rejected
  withdrawn

  @@schema("core")
}

enum TeamMemberRole {
  manager
  head_coach
  part_coach
  player
  staff

  @@schema("core")
}

enum TeamMemberStatus {
  pending
  active
  suspended
  left

  @@schema("core")
}

enum PlayerRosterStatus {
  active
  injured
  leave_absence
  military_leave
  tryout
  inactive

  @@schema("core")
}

// ---------------------------------------------------------------------------
// training enums
// ---------------------------------------------------------------------------

enum EventType {
  practice
  game
  meeting
  rehab

  @@schema("training")
}

enum EventStatus {
  scheduled
  cancelled
  completed

  @@schema("training")
}

enum AttendanceStatus {
  attending
  absent
  undecided

  @@schema("training")
}

enum TrainingScheduleStatus {
  draft
  submitted
  approved
  rejected
  published
  archived

  @@schema("training")
}

enum TrainingBlockType {
  drill
  break
  meeting
  film
  warmup
  other

  @@schema("training")
}

enum TrainingBlockIntensity {
  low
  medium
  high

  @@schema("training")
}

enum TrainingColumnUnit {
  team
  offense
  defense
  special

  @@schema("training")
}

enum PracticeCheckinStatus {
  draft
  submitted

  @@schema("training")
}

// ---------------------------------------------------------------------------
// development enums
// ---------------------------------------------------------------------------

enum IipAssignmentStatus {
  assigned
  in_progress
  completed
  cancelled
  expired

  @@schema("development")
}

// ---------------------------------------------------------------------------
// management enums
// ---------------------------------------------------------------------------

enum MonthlyDueStatus {
  unpaid
  paid
  waived
  partial

  @@schema("management")
}

enum InjuryApprovalStatus {
  pending
  confirmed
  rejected

  @@schema("management")
}

enum InjuryReportType {
  player_self
  staff_report

  @@schema("management")
}

enum ParticipationLevel {
  full
  limited
  out

  @@schema("management")
}

// ---------------------------------------------------------------------------
// core
// ---------------------------------------------------------------------------

model Team {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  metadata    Json      @default("{}") @map("metadata") @db.JsonB

  name         String  @map("name")
  teamCode     String  @unique @map("team_code")
  sport        String  @default("american_football") @map("sport")
  city         String? @map("city")
  seasonYear   Int     @map("season_year")
  description  String? @map("description")
  ownerUserId  String? @map("owner_user_id") @db.Uuid

  players           Player[]
  teamMembers       TeamMember[]
  joinRequests      JoinRequest[]
  events            Event[]
  attendances       Attendance[]
  trainingSchedules TrainingSchedule[]
  drillLibraries    DrillLibrary[]
  performanceScores PerformanceScore[]
  iipAssignments    IipAssignment[]
  injuryReports     InjuryReport[]
  conditionLogs     ConditionLog[]
  monthlyDues       MonthlyDue[]
  practiceCheckins  PracticeCheckin[]

  @@schema("core")
  @@map("teams")
}

model Profile {
  id        String    @id @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  displayName String? @map("display_name")
  phone       String? @map("phone")
  birthYear   Int?    @map("birth_year")
  avatarUrl   String? @map("avatar_url")

  @@schema("core")
  @@map("profiles")
}

model Player {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId           String             @map("team_id") @db.Uuid
  team             Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  linkedUserId     String?            @map("linked_user_id") @db.Uuid
  fullName         String             @map("full_name")
  jerseyNumber     Int?               @map("jersey_number")
  primaryPosition  String?            @map("primary_position")
  secondaryPosition String?           @map("secondary_position")
  unit             String?            @map("unit")
  heightCm         Decimal?           @map("height_cm") @db.Decimal(5, 1)
  weightKg         Decimal?           @map("weight_kg") @db.Decimal(5, 1)
  joinYear         Int?               @map("join_year")
  rosterStatus     PlayerRosterStatus @default(active) @map("roster_status")
  notes            String?            @map("notes")

  teamMembers       TeamMember[]
  attendances       Attendance[]
  performanceScores PerformanceScore[]
  iipAssignments    IipAssignment[]
  injuryReports     InjuryReport[]
  conditionLogs     ConditionLog[]
  monthlyDues       MonthlyDue[]
  practiceCheckins  PracticeCheckin[]

  @@schema("core")
  @@map("players")
}

model TeamMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId    String             @map("team_id") @db.Uuid
  team      Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String             @map("user_id") @db.Uuid
  role      TeamMemberRole
  status    TeamMemberStatus   @default(pending)
  playerId  String?            @map("player_id") @db.Uuid
  player    Player?            @relation(fields: [playerId], references: [id])
  joinedAt  DateTime?          @map("joined_at") @db.Timestamptz(6)
  invitedBy String?            @map("invited_by") @db.Uuid

  @@unique([teamId, userId])
  @@schema("core")
  @@map("team_members")
}

model JoinRequest {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId            String            @map("team_id") @db.Uuid
  team              Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId            String            @map("user_id") @db.Uuid
  requestedRole     TeamMemberRole    @map("requested_role")
  requestedPosition String?         @map("requested_position")
  requestedUnit     String?          @map("requested_unit")
  jerseyNumber      Int?             @map("jersey_number")
  heightCm          Decimal?         @map("height_cm") @db.Decimal(5, 1)
  weightKg          Decimal?         @map("weight_kg") @db.Decimal(5, 1)
  message           String            @map("message")
  status            JoinRequestStatus @default(pending)
  reviewedBy        String?          @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  rejectReason      String?          @map("reject_reason")

  @@index([teamId, status])
  @@schema("core")
  @@map("join_requests")
}

// ---------------------------------------------------------------------------
// training
// ---------------------------------------------------------------------------

model Event {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId      String      @map("team_id") @db.Uuid
  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title       String      @map("title")
  eventType   EventType   @default(practice) @map("event_type")
  startsAt    DateTime    @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime?   @map("ends_at") @db.Timestamptz(6)
  location    String?     @map("location")
  opponent    String?     @map("opponent")
  isMandatory Boolean     @default(false) @map("is_mandatory")
  notes       String?     @map("notes")
  status      EventStatus @default(scheduled)

  attendances       Attendance[]
  performanceScores PerformanceScore[]
  practiceCheckins  PracticeCheckin[]

  @@index([teamId, startsAt])
  @@schema("training")
  @@map("events")
}

model Attendance {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId              String           @map("team_id") @db.Uuid
  team                Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  eventId             String           @map("event_id") @db.Uuid
  event               Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  playerId            String           @map("player_id") @db.Uuid
  player              Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  status              AttendanceStatus @default(undecided)
  absenceReason       String?          @map("absence_reason")
  lastChangedByUserId String?          @map("last_changed_by_user_id") @db.Uuid

  @@unique([eventId, playerId])
  @@index([teamId, eventId])
  @@schema("training")
  @@map("attendance")
}

model TrainingSchedule {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId        String                 @map("team_id") @db.Uuid
  team          Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title         String                 @map("title")
  scheduleDate  DateTime               @map("schedule_date") @db.Date
  timezone      String                 @default("Asia/Seoul") @map("timezone")
  location      String?                @map("location")
  status        TrainingScheduleStatus @default(draft)
  coachAuthorId String?                @map("coach_author_id") @db.Uuid
  submittedAt   DateTime?              @map("submitted_at") @db.Timestamptz(6)
  approvedBy    String?                @map("approved_by") @db.Uuid
  approvedAt    DateTime?              @map("approved_at") @db.Timestamptz(6)
  rejectedBy    String?                @map("rejected_by") @db.Uuid
  rejectedAt    DateTime?              @map("rejected_at") @db.Timestamptz(6)
  rejectReason  String?                @map("reject_reason")
  publishedAt   DateTime?              @map("published_at") @db.Timestamptz(6)

  blocks TrainingBlock[]

  @@index([teamId, scheduleDate])
  @@index([teamId, status])
  @@schema("training")
  @@map("training_schedules")
}

model TrainingBlock {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  trainingScheduleId String                 @map("training_schedule_id") @db.Uuid
  schedule           TrainingSchedule       @relation(fields: [trainingScheduleId], references: [id], onDelete: Cascade)
  coachUserId        String                 @map("coach_user_id") @db.Uuid
  blockType          TrainingBlockType      @default(drill) @map("block_type")
  columnUnit         TrainingColumnUnit     @map("column_unit")
  title              String                 @map("title")
  startsAt           DateTime               @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime               @map("ends_at") @db.Timestamptz(6)
  intensity          TrainingBlockIntensity? @map("intensity")
  positionFocus      String?                @map("position_focus")
  sortOrder          Int                    @default(0) @map("sort_order")
  parentBlockId      String?                @map("parent_block_id") @db.Uuid
  parentBlock        TrainingBlock?         @relation("BlockHierarchy", fields: [parentBlockId], references: [id])
  childBlocks        TrainingBlock[]        @relation("BlockHierarchy")

  @@index([trainingScheduleId])
  @@schema("training")
  @@map("training_blocks")
}

model PracticeCheckin {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId               String                @map("team_id") @db.Uuid
  team                 Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId             String                @map("player_id") @db.Uuid
  player               Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)
  coachUserId          String?               @map("coach_user_id") @db.Uuid
  eventId              String?               @map("event_id") @db.Uuid
  event                Event?                @relation(fields: [eventId], references: [id])
  practiceDate         DateTime              @map("practice_date") @db.Date
  status               PracticeCheckinStatus @default(draft)
  starRating           Int?                  @map("star_rating")
  effortTag            String?               @map("effort_tag")
  coachCommentOneLiner String?               @map("coach_comment_one_liner")

  @@index([teamId, playerId, practiceDate])
  @@schema("training")
  @@map("practice_checkins")
}

// ---------------------------------------------------------------------------
// development
// ---------------------------------------------------------------------------

model DrillLibrary {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId             String?   @map("team_id") @db.Uuid
  team               Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name               String    @map("name")
  description        String?   @map("description")
  defaultXp          Int       @default(0) @map("default_xp")
  suggestedUnit      String?   @map("suggested_unit")
  suggestedPositions String[]  @map("suggested_positions")

  iipAssignments IipAssignment[]

  @@index([teamId])
  @@schema("development")
  @@map("drill_library")
}

model PerformanceScore {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId           String    @map("team_id") @db.Uuid
  team             Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId         String    @map("player_id") @db.Uuid
  player           Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  coachUserId      String    @map("coach_user_id") @db.Uuid
  sourceEventId    String?   @map("source_event_id") @db.Uuid
  sourceEvent      Event?    @relation(fields: [sourceEventId], references: [id])
  evaluatedOn      DateTime  @map("evaluated_on") @db.Date
  physical         Decimal   @map("physical") @db.Decimal(4, 1)
  skill            Decimal   @map("skill") @db.Decimal(4, 1)
  tactical         Decimal   @map("tactical") @db.Decimal(4, 1)
  attendanceMetric Decimal   @map("attendance_metric") @db.Decimal(4, 1)
  mental           Decimal   @map("mental") @db.Decimal(4, 1)
  coachComment     String?   @map("coach_comment")
  keywordTags      String[]  @default([]) @map("keyword_tags")
  isVisibleToPlayer Boolean  @default(true) @map("is_visible_to_player")

  iipFromSource IipAssignment[] @relation("PerfToIip")

  @@index([teamId, playerId])
  @@schema("development")
  @@map("performance_scores")
}

model IipAssignment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId                   String              @map("team_id") @db.Uuid
  team                     Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId                 String              @map("player_id") @db.Uuid
  player                   Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  coachUserId              String              @map("coach_user_id") @db.Uuid
  drillLibraryId           String?             @map("drill_library_id") @db.Uuid
  drill                    DrillLibrary?       @relation(fields: [drillLibraryId], references: [id])
  sourcePerformanceScoreId String?             @map("source_performance_score_id") @db.Uuid
  sourcePerformance        PerformanceScore?   @relation("PerfToIip", fields: [sourcePerformanceScoreId], references: [id])
  title                    String              @map("title")
  description              String?             @map("description")
  dueAt                    DateTime            @map("due_at") @db.Timestamptz(6)
  status                   IipAssignmentStatus @default(assigned)
  xpEarned                 Int                 @default(0) @map("xp_earned")
  completedAt              DateTime?           @map("completed_at") @db.Timestamptz(6)
  completionNote           String?             @map("completion_note")

  @@index([teamId, playerId, status])
  @@index([sourcePerformanceScoreId])
  @@schema("development")
  @@map("iip_assignments")
}

// ---------------------------------------------------------------------------
// management
// ---------------------------------------------------------------------------

model InjuryReport {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId               String                 @map("team_id") @db.Uuid
  team                 Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId             String                 @map("player_id") @db.Uuid
  player               Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reportType           InjuryReportType       @default(staff_report) @map("report_type")
  bodyPart             String                 @map("body_part")
  painLevel            Int                    @map("pain_level")
  symptoms             String?                @map("symptoms")
  participationLevel   ParticipationLevel     @map("participation_level")
  expectedReturnDate   DateTime?              @map("expected_return_date") @db.Date
  isActive             Boolean                @default(false) @map("is_active")
  approvalStatus       InjuryApprovalStatus   @default(pending) @map("approval_status")
  confirmedBy          String?                @map("confirmed_by") @db.Uuid
  confirmedAt          DateTime?              @map("confirmed_at") @db.Timestamptz(6)
  rejectedBy           String?                @map("rejected_by") @db.Uuid
  rejectedAt           DateTime?              @map("rejected_at") @db.Timestamptz(6)
  rejectReason         String?                @map("reject_reason")

  @@index([teamId, approvalStatus])
  @@schema("management")
  @@map("injury_reports")
}

model ConditionLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId         String   @map("team_id") @db.Uuid
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId       String   @map("player_id") @db.Uuid
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  loggedOn       DateTime @map("logged_on") @db.Date
  conditionScore Decimal  @map("condition_score") @db.Decimal(4, 1)
  energyScore    Decimal  @map("energy_score") @db.Decimal(4, 1)
  mentalScore    Decimal  @map("mental_score") @db.Decimal(4, 1)
  sleepHours     Decimal? @map("sleep_hours") @db.Decimal(4, 1)
  notes          String?  @map("notes")

  @@index([playerId, loggedOn])
  @@schema("management")
  @@map("condition_logs")
}

model MonthlyDue {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  metadata  Json      @default("{}") @map("metadata") @db.JsonB

  teamId      String           @map("team_id") @db.Uuid
  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId    String           @map("player_id") @db.Uuid
  player      Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  dueMonth    String           @map("due_month") @db.Char(7)
  amountCents BigInt           @default(0) @map("amount_cents")
  currency    String           @default("KRW") @map("currency")
  status      MonthlyDueStatus @default(unpaid)
  paidAt      DateTime?        @map("paid_at") @db.Date

  @@unique([teamId, playerId, dueMonth])
  @@schema("management")
  @@map("monthly_dues")
}
