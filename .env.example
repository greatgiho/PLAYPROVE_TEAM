# Prisma / Supabase Postgres
# 반드시 postgresql:// 또는 postgres:// 로 시작 (https:// 가 아님 — 그건 REST API용 Project URL)
# Settings → Database → Connection string → URI 에서 복사
# 비밀번호에 @ # 등이 있으면 URL 인코딩 필요
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Supabase API (시드에서 Auth 자동 생성 시 필요)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# 로스터 페이지: DB(Prisma)에서 팀을 불러올 때 team_code (시드와 맞출 것)
NEXT_PUBLIC_PLAYPROVE_TEAM_CODE="seoul_dragons_fc"
# 대시보드 → Settings → API → service_role (시드에서 고정 UUID auth 사용자 생성 시 필수)
SUPABASE_SERVICE_ROLE_KEY=""

# 시드: 위 service_role 이 없으면, Auth에서 만든 사용자 UUID 3개를 직접 지정
# SEED_MANAGER_USER_ID=""
# SEED_COACH_USER_ID=""
# SEED_PLAYER_USER_ID=""
# SEED_AUTH_PASSWORD="PlayproveSeed!ChangeMe"
